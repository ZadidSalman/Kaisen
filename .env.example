# MONGODB_URI: Connection string for MongoDB Atlas (must include /kaikansen database name)
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/kaikansen"

# JWT Secrets: 64-character random strings for token signing
JWT_SECRET="YOUR_JWT_SECRET"
JWT_REFRESH_SECRET="YOUR_JWT_REFRESH_SECRET"

# VOYAGE_API_KEY: For vector embeddings (from Atlas AI Models panel)
VOYAGE_API_KEY="YOUR_VOYAGE_API_KEY"

# CRON_SECRET: To protect the seasonal sync endpoint
CRON_SECRET="YOUR_CRON_SECRET"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
